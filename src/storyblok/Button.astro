---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
// console.log(blok.link);
---

<a class={`btn ${blok.style}`} href={blok.link.url} {...storyblokEditable(blok)}
  >{blok.label}</a
>

<style>
  .btn {
    @apply font-semibold md:text-base text-sm transition-colors rounded-full md:px-8 px-7 md:py-4 py-3;
  }
  .primary {
    @apply bg-neutral-50 text-neutral-900 hover:bg-neutral-950 hover:text-neutral-200;
  }
  .secondary {
    @apply bg-neutral-950 text-neutral-50 hover:bg-neutral-50 hover:text-neutral-950;
  }
</style>
